APP_NAME=correspondencia
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://your-server-ip-or-domain
APP_LC_TIME=es_BO.utf8
APP_LOCALE=es
APP_TIMEZONE=America/La_Paz

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=correspondencia
DB_USERNAME=admin
DB_PASSWORD=admin

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_DOMAIN=your-server-ip-or-domain
SANCTUM_STATEFUL_DOMAINS=your-server-ip-or-domain

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_SSL=false
MQTT_DEBUG=false

MEMCACHED_HOST=memcached

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
MIX_BASE_URL="${APP_URL}"
MIX_MQTT_HOST=your-server-ip-or-domain
MIX_MQTT_PORT=9001
MIX_MQTT_SSL="${MQTT_SSL}"
